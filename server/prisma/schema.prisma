// =============================================================================
// University Web System — Prisma schema (PostgreSQL)
// Source of truth: docs/2-database-schema.md
// Domains: Users | Structure | Academic | Library | News & Audit
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  ADMIN
  STUDENT
  FACULTY
  LIBRARIAN
  AFFAIRS
  MANAGER
  EXAM_OFFICER
}

enum GradeAppealStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TranscriptRequestStatus {
  PENDING
  AFFAIRS_APPROVED
  PROCESSED
  DELIVERED
  REJECTED
}

enum NewsCategory {
  ANNOUNCEMENT
  WORKSHOP
  TRAINING
  TUITION
}

enum TuitionInstallmentStatus {
  PENDING
  PARTIAL
  PAID
}

enum DiscountRequestType {
  MARTYR_RELATIVE
  ACADEMIC_EXCELLENCE
  HUMANITARIAN
}

enum DiscountRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LibraryBookCategory {
  MEDICAL
  ADMINISTRATIVE
  SCIENTIFIC
  PROGRAMMING
  FRONTEND_WEB
  BACKEND_WEB
  ARTIFICIAL_INTELLIGENCE
  GRADUATION_PROJECT
}

enum StudyTerm {
  FIRST
  SECOND
}

enum NotificationKind {
  NEWS
  TRANSCRIPT_REQUEST
  TRANSCRIPT_READY
  TRANSCRIPT_REJECTED
  APPEAL_SUBMITTED
  APPEAL_RESOLVED
  DISCOUNT_REQUEST
  DISCOUNT_RESOLVED
  GRADE_PUBLISHED
  PRACTICAL_GRADE_PUBLISHED
  GRADE_SUBMISSION
  GRADE_SUBMISSION_REJECTED
  MANAGER_REQUEST
  MANAGER_REQUEST_RESOLVED
}

enum GradeSubmissionStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  REJECTED
}

enum GradeSubmissionPhase {
  PRACTICAL
  THEORY
}

enum ManagerRequestStatus {
  PENDING
  RESOLVED
  REJECTED
}

// -----------------------------------------------------------------------------
// User management
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      UserRole
  active    Boolean  @default(true)
  collegeId String?  @map("college_id") @db.Uuid
  college   College? @relation(fields: [collegeId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  studentProfile Student?
  facultyCourses FacultyCourse[] @relation("FacultyCourses")
  gradeSubmissions GradeSubmission[] @relation("GradeSubmissionsByFaculty")
  gradeSubmissionsPublished GradeSubmission[] @relation("GradeSubmissionsPublished")
  booksAdded     Book[]          @relation("BookAddedBy")
  newsArticles   News[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  managerRequests     ManagerRequest[]     @relation("ManagerRequests")
  resolvedMgrRequests ManagerRequest[]     @relation("ManagerRequestResolver")

  @@map("users")
}

/// College manager request to system admin.
model ManagerRequest {
  id            String               @id @default(uuid()) @db.Uuid
  managerId     String               @map("manager_id") @db.Uuid
  manager       User                 @relation("ManagerRequests", fields: [managerId], references: [id])
  subject       String
  body          String               @db.Text
  status        ManagerRequestStatus @default(PENDING)
  adminResponse String?              @map("admin_response") @db.Text
  resolvedById  String?              @map("resolved_by_id") @db.Uuid
  resolvedBy    User?                @relation("ManagerRequestResolver", fields: [resolvedById], references: [id])
  createdAt     DateTime             @default(now()) @map("created_at")
  resolvedAt    DateTime?            @map("resolved_at")

  @@index([status, createdAt])
  @@map("manager_requests")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  title     String
  body      String           @db.Text
  linkPath  String           @map("link_path")
  meta      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

// -----------------------------------------------------------------------------
// University structure
// -----------------------------------------------------------------------------

model College {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  description String       @db.Text
  departments Department[]
  users       User[]
  news        News[]
  tuitionConfig CollegeTuitionConfig?

  @@map("colleges")
}

model Department {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?  @db.Text
  collegeId   String   @map("college_id") @db.Uuid
  college     College  @relation(fields: [collegeId], references: [id])
  courses            Course[]
  curriculumCourses  CurriculumCourse[]
  students           Student[]
  books              Book[]

  @@map("departments")
}

model Course {
  id           String          @id @default(uuid()) @db.Uuid
  name         String
  code         String          @unique
  departmentId String          @map("department_id") @db.Uuid
  department   Department      @relation(fields: [departmentId], references: [id])
  enrollments  Enrollment[]
  facultyLinks FacultyCourse[]

  @@map("courses")
}

/// Links faculty users to course offerings (semester / academic year).
model FacultyCourse {
  id           String   @id @default(uuid()) @db.Uuid
  facultyId    String   @map("faculty_id") @db.Uuid
  faculty      User     @relation("FacultyCourses", fields: [facultyId], references: [id])
  courseId     String   @map("course_id") @db.Uuid
  course       Course   @relation(fields: [courseId], references: [id])
  semester     String
  academicYear String   @map("academic_year")
  examResults  ExamResult[]
  gradeSubmission GradeSubmission?

  @@index([facultyId])
  @@index([courseId])
  @@map("faculty_courses")
}

// -----------------------------------------------------------------------------
// Academic & student affairs
// -----------------------------------------------------------------------------

model Student {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @unique @map("user_id") @db.Uuid
  user                User                 @relation(fields: [userId], references: [id])
  departmentId        String               @map("department_id") @db.Uuid
  department          Department           @relation(fields: [departmentId], references: [id])
  academicNumber      String               @unique @map("academic_number")
  currentSemester     Int                  @map("current_semester")
  academicYear        String               @map("academic_year")
  enrollments         Enrollment[]
  examResults         ExamResult[]
  gradeAppeals        GradeAppeal[]
  transcriptRequests  TranscriptRequest[]
  tuitionInstallments StudentTuitionInstallment[]
  tuitionPayments     TuitionPayment[]
  discountRequests    DiscountRequest[]
  curriculumGrades    StudentCurriculumGrade[]
  gradeSubmissionLines GradeSubmissionLine[]

  @@map("students")
}

/// Planned course in the official study plan (per department, year, and term).
model CurriculumCourse {
  id             String                   @id @default(uuid()) @db.Uuid
  departmentId   String                   @map("department_id") @db.Uuid
  department     Department               @relation(fields: [departmentId], references: [id])
  studyYear      Int                      @map("study_year")
  term           StudyTerm
  name           String
  code           String                   @unique
  practicalPass  Int                      @default(16) @map("practical_pass")
  theoryPass     Int                      @default(60) @map("theory_pass")
  sortOrder      Int                      @default(0) @map("sort_order")
  studentGrades  StudentCurriculumGrade[]

  @@unique([departmentId, studyYear, term, code])
  @@index([departmentId, studyYear, term])
  @@map("curriculum_courses")
}

/// Student scores on curriculum courses (practical / theoretical components).
model StudentCurriculumGrade {
  id                 String           @id @default(uuid()) @db.Uuid
  studentId          String           @map("student_id") @db.Uuid
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  curriculumCourseId String           @map("curriculum_course_id") @db.Uuid
  curriculumCourse   CurriculumCourse @relation(fields: [curriculumCourseId], references: [id], onDelete: Cascade)
  practicalScore     Decimal?         @map("practical_score") @db.Decimal(5, 2)
  theoryScore        Decimal?         @map("theory_score") @db.Decimal(5, 2)

  @@unique([studentId, curriculumCourseId])
  @@map("student_curriculum_grades")
}

model Enrollment {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  student      Student  @relation(fields: [studentId], references: [id])
  courseId     String   @map("course_id") @db.Uuid
  course       Course   @relation(fields: [courseId], references: [id])
  semester     String
  academicYear String   @map("academic_year")

  @@map("enrollments")
}

model ExamResult {
  id              String        @id @default(uuid()) @db.Uuid
  studentId       String        @map("student_id") @db.Uuid
  student         Student       @relation(fields: [studentId], references: [id])
  facultyCourseId String        @map("faculty_course_id") @db.Uuid
  facultyCourse   FacultyCourse @relation(fields: [facultyCourseId], references: [id])
  score           Decimal       @db.Decimal(5, 2)
  practicalScore  Decimal?      @map("practical_score") @db.Decimal(5, 2)
  theoryScore     Decimal?      @map("theory_score") @db.Decimal(5, 2)
  attemptNumber   Int           @default(1) @map("attempt_number")
  semester        String
  academicYear    String        @map("academic_year")
  /// PostgreSQL DATE (spec: result_date Date, default now).
  resultDate      DateTime      @default(now()) @map("result_date") @db.Date
  gradeAppeals    GradeAppeal[]

  @@unique([studentId, facultyCourseId, attemptNumber])
  @@map("exam_results")
}

model GradeAppeal {
  id            String              @id @default(uuid()) @db.Uuid
  studentId     String              @map("student_id") @db.Uuid
  student       Student             @relation(fields: [studentId], references: [id])
  examResultId  String              @map("exam_result_id") @db.Uuid
  examResult    ExamResult          @relation(fields: [examResultId], references: [id])
  reason        String              @db.Text
  status        GradeAppealStatus
  adminResponse String?             @map("admin_response") @db.Text
  submittedAt   DateTime            @default(now()) @map("submitted_at")

  @@map("grade_appeals")
}

/// Faculty-submitted grade batch per course section; published by exam officer.
model GradeSubmission {
  id              String                @id @default(uuid()) @db.Uuid
  facultyCourseId String                @unique @map("faculty_course_id") @db.Uuid
  facultyCourse   FacultyCourse         @relation(fields: [facultyCourseId], references: [id])
  facultyId       String                @map("faculty_id") @db.Uuid
  faculty         User                  @relation("GradeSubmissionsByFaculty", fields: [facultyId], references: [id])
  status               GradeSubmissionStatus @default(DRAFT)
  phase                GradeSubmissionPhase  @default(PRACTICAL)
  practicalPublishedAt DateTime?             @map("practical_published_at")
  rejectionReason      String?               @map("rejection_reason") @db.Text
  submittedAt          DateTime?             @map("submitted_at")
  publishedAt          DateTime?             @map("published_at")
  publishedById   String?               @map("published_by") @db.Uuid
  publishedBy     User?                 @relation("GradeSubmissionsPublished", fields: [publishedById], references: [id])
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  lines           GradeSubmissionLine[]

  @@index([status])
  @@index([facultyId])
  @@map("grade_submissions")
}

model GradeSubmissionLine {
  id             String          @id @default(uuid()) @db.Uuid
  submissionId   String          @map("submission_id") @db.Uuid
  submission     GradeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  studentId      String          @map("student_id") @db.Uuid
  student        Student         @relation(fields: [studentId], references: [id])
  practicalScore Decimal  @map("practical_score") @db.Decimal(5, 2)
  theoryScore    Decimal? @map("theory_score") @db.Decimal(5, 2)

  @@unique([submissionId, studentId])
  @@map("grade_submission_lines")
}

model TranscriptRequest {
  id                String                   @id @default(uuid()) @db.Uuid
  studentId         String                   @map("student_id") @db.Uuid
  student           Student                  @relation(fields: [studentId], references: [id])
  status            TranscriptRequestStatus
  filePath          String?                  @map("file_path")
  rejectionReason   String?                  @map("rejection_reason") @db.Text
  feeAmount         Float                    @default(5) @map("fee_amount")
  feePaid           Boolean                  @default(false) @map("fee_paid")
  feeRefunded       Boolean                  @default(false) @map("fee_refunded")
  paymentReference  String?                  @map("payment_reference")
  paidAt            DateTime?                @map("paid_at")
  requestedAt       DateTime                 @default(now()) @map("requested_at")
  affairsReviewedAt DateTime?                @map("affairs_reviewed_at")
  processedAt       DateTime?                @map("processed_at")

  @@map("transcript_requests")
}

// -----------------------------------------------------------------------------
// Library
// -----------------------------------------------------------------------------

model Book {
  id              String              @id @default(uuid()) @db.Uuid
  title           String
  filePath        String              @map("file_path")
  category        LibraryBookCategory @default(SCIENTIFIC)
  departmentId    String?             @map("department_id") @db.Uuid
  department      Department?         @relation(fields: [departmentId], references: [id])
  addedById       String        @map("added_by") @db.Uuid
  addedBy         User          @relation("BookAddedBy", fields: [addedById], references: [id])
  downloadsCount  Int           @default(0) @map("downloads_count")
  readsCount      Int           @default(0) @map("reads_count")
  publishYear     Int           @map("publish_year")
  author          String?
  publisher       String?
  createdAt       DateTime      @default(now()) @map("created_at")
  keywords        BookKeyword[]

  @@map("books")
}

model BookKeyword {
  id      String @id @default(uuid()) @db.Uuid
  bookId  String @map("book_id") @db.Uuid
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  keyword String

  @@map("book_keywords")
}

// -----------------------------------------------------------------------------
// News & audit
// -----------------------------------------------------------------------------

model News {
  id           String       @id @default(uuid()) @db.Uuid
  title        String
  content      String       @db.Text
  imageUrl     String?      @map("image_url")
  category           NewsCategory @default(ANNOUNCEMENT)
  enablePayNow       Boolean      @default(false) @map("enable_pay_now")
  /// When category is TUITION: semester-1 | semester-2 — which installment pay box to unlock.
  tuitionSemesterKey String?      @map("tuition_semester_key")
  collegeId    String?      @map("college_id") @db.Uuid
  college      College?     @relation(fields: [collegeId], references: [id])
  authorId     String       @map("author_id") @db.Uuid
  author       User         @relation(fields: [authorId], references: [id])
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("news")
}

// -----------------------------------------------------------------------------
// Tuition & payments (simulated)
// -----------------------------------------------------------------------------

model CollegeTuitionConfig {
  id             String  @id @default(uuid()) @db.Uuid
  collegeId      String  @unique @map("college_id") @db.Uuid
  college        College @relation(fields: [collegeId], references: [id])
  totalAmount    Decimal @map("total_amount") @db.Decimal(10, 2)
  semesterAmount Decimal @map("semester_amount") @db.Decimal(10, 2)

  @@map("college_tuition_configs")
}

model StudentTuitionInstallment {
  id              String                   @id @default(uuid()) @db.Uuid
  studentId       String                   @map("student_id") @db.Uuid
  student         Student                  @relation(fields: [studentId], references: [id])
  academicYear    String                   @map("academic_year")
  semesterKey     String                   @map("semester_key")
  label           String
  amountDue       Decimal                  @map("amount_due") @db.Decimal(10, 2)
  amountPaid      Decimal                  @default(0) @map("amount_paid") @db.Decimal(10, 2)
  status          TuitionInstallmentStatus @default(PENDING)
  payments        TuitionPayment[]

  @@unique([studentId, academicYear, semesterKey])
  @@map("student_tuition_installments")
}

model TuitionPayment {
  id            String                    @id @default(uuid()) @db.Uuid
  studentId     String                    @map("student_id") @db.Uuid
  student       Student                   @relation(fields: [studentId], references: [id])
  installmentId String                    @map("installment_id") @db.Uuid
  installment   StudentTuitionInstallment @relation(fields: [installmentId], references: [id])
  amount        Decimal                   @db.Decimal(10, 2)
  referenceCode String                    @unique @map("reference_code")
  method        String                    @default("SIMULATED")
  paidAt        DateTime                  @default(now()) @map("paid_at")

  @@map("tuition_payments")
}

model DiscountRequest {
  id              String                @id @default(uuid()) @db.Uuid
  studentId       String                @map("student_id") @db.Uuid
  student         Student               @relation(fields: [studentId], references: [id])
  type            DiscountRequestType
  notes           String?               @db.Text
  proofFilePath   String?               @map("proof_file_path")
  status          DiscountRequestStatus @default(PENDING)
  discountPercent Decimal?              @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal?              @map("discount_amount") @db.Decimal(10, 2)
  adminResponse   String?               @map("admin_response") @db.Text
  submittedAt     DateTime              @default(now()) @map("submitted_at")
  reviewedAt      DateTime?             @map("reviewed_at")

  @@map("discount_requests")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String   @map("entity_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
