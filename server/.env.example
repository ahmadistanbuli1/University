# Server environment (copy to `server/.env`)
# PostgreSQL — use `docker compose up -d` from repo root for a local database.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/university?schema=public"

# Optional: direct URL for Prisma Migrate (same as DATABASE_URL if not using PgBouncer)
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/university?schema=public"

JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_EXPIRES_IN="7d"
PORT=4000
UPLOAD_DIR="./uploads"
CLIENT_ORIGIN="http://localhost:5173"
