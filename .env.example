# Copy to server/.env (see also server/.env.example) and client/.env as needed.
# Local PostgreSQL: run `docker compose up -d` from the repo root, then:

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/university?schema=public"
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_EXPIRES_IN="7d"
PORT=4000
UPLOAD_DIR="./uploads"
CLIENT_ORIGIN="http://localhost:5173"
